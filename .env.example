# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# Nothing here is needed yet — we'll wire each one in as we build the package that uses it.

# ── LLM: the agent's reasoning + the LLM-as-judge grader ───────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Embeddings + reranking for the RAG pipeline ───────────────────────
# https://dashboard.voyageai.com/
VOYAGE_API_KEY=

# ── Evidence retrieval: web/news search that feeds the RAG corpus ─────
# https://app.tavily.com/
TAVILY_API_KEY=

# ── Vector store: local Postgres + pgvector, run via Docker ───────────
# Started with `docker compose up -d` (we add the compose file in the RAG step).
# This URL matches the credentials defined in that compose file.
DATABASE_URL=postgresql://lykos:lykos@localhost:5432/lykos

# ── Prediction markets ────────────────────────────────────────────────
# Polymarket Gamma API: read-only market data + resolved outcomes. No key required.
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# Optional — Kalshi DEMO/sandbox for placing orders with fake money (safe).
# Leave commented until we add live order placement.
# KALSHI_API_BASE=https://demo-api.kalshi.co/trade-api/v2
# KALSHI_API_KEY_ID=
# KALSHI_PRIVATE_KEY_PATH=
