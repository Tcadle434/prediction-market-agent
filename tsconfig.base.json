{
	"$schema": "https://json.schemastore.org/tsconfig",
	"// note": "Shared compiler settings. Every package extends this and only sets its own paths (rootDir/outDir).",
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",

		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"verbatimModuleSyntax": true,

		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,

		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	}
}
