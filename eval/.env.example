# Copy to eval/.env and fill in. Gitignored.

# ── Hosted LangSmith (datasets + experiments + tracing) ───────────────
# Free account + key: https://smith.langchain.com  → Settings → API Keys
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=lykos-eval

# ── Judge model (Anthropic) ───────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Override the judge model if you like:
LYKOS_JUDGE_MODEL=anthropic:claude-haiku-4-5-20251001

# Name of the dataset created/used in LangSmith
LYKOS_DATASET=lykos-groundedness
